{
  "hooks": [
    {
      "event": "SessionStart",
      "command": "~/.claude/bin/memory-hook --host claude --event session-start",
      "stdin": true
    },
    {
      "event": "UserPromptSubmit",
      "command": "~/.claude/bin/memory-hook --host claude --event prompt-submit",
      "stdin": true
    },
    {
      "event": "Notification",
      "command": "~/.claude/bin/memory-hook --host claude --event notification",
      "stdin": true
    },
    {
      "event": "Stop",
      "command": "~/.claude/bin/memory-hook --host claude --event stop",
      "stdin": true
    }
  ]
}
