      },
      "output": {
        "type": "json",
        "fields": ["status", "targets", "watcher_pid", "deliver_enabled"]
      },
      "preconditions": ["formal_session_exists", "pane_titles_applied"],
      "postconditions": ["watcher_armed", "watcher_process_running"]
    },
