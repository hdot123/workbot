{
  "$schema": "http://json-schema.org/draft-2020-12/schema#",
  "$id": "aedu://schema/chapter-tree/v1.0.0",
  "title": "章节树表 Schema",
  "description": "教育孪生项目章节树表结构定义 - 首发版本 (安徽省/高中/高一/物理/PEP_G1_V1)",
  "version": "1.0.0",
  "type": "object",
  "definitions": {
    "node_level": {
      "type": "string",
      "enum": ["volume", "chapter", "section", "subsection"],
      "description": "节点层级枚举 - MVP 仅支持 4 层"
    },
    "node_type": {
      "type": "string",
      "enum": ["normal", "experiment", "review", "reading", "appendix", "activity"],
      "description": "节点类型枚举"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated"],
      "description": "节点状态"
    },
    "chapter_node": {
      "type": "object",
      "required": [
        "chapter_node_id",
        "region_id",
        "curriculum_version_id",
        "subject",
        "grade_level",
        "volume_no",
        "node_level",
        "node_code",
        "node_name",
        "root_node_id",
        "order_index",
        "status",
        "version"
      ],
      "properties": {
        "chapter_node_id": {
          "type": "string",
          "pattern": "^PHY_PEP_G1_V1_(VOL|CH|SEC|SUBSEC)_[0-9]{2}(_[0-9]{2})*$",
          "description": "章节节点唯一标识"
        },
        "region_id": {
          "type": "string",
          "const": "CN_AH",
          "description": "地区标识（冻结值：安徽省）"
        },
        "curriculum_version_id": {
          "type": "string",
          "const": "PHY_PEP_G1_V1",
          "description": "教材版本标识（冻结值）"
        },
        "subject": {
          "type": "string",
          "const": "物理",
          "description": "学科（冻结值）"
        },
        "grade_level": {
          "type": "string",
          "const": "高一",
          "description": "年级（冻结值）"
        },
        "volume_no": {
          "type": "string",
          "const": "必修一",
          "description": "册别（冻结值）"
        },
        "node_level": {
          "$ref": "#/definitions/node_level"
        },
        "node_code": {
          "type": "string",
          "pattern": "^[0-9]{2}(\\.[0-9]{2})*$",
          "description": "节点编码（层级点分十进制）"
        },
        "node_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "节点名称"
        },
        "parent_node_id": {
          "type": ["string", "null"],
          "description": "父节点标识（顶层节点为 null）"
        },
        "root_node_id": {
          "type": "string",
          "const": "PHY_PEP_G1_V1_ROOT",
          "description": "所属根节点标识"
        },
        "order_index": {
          "type": "integer",
          "minimum": 1,
          "description": "同层排序序号"
        },
        "full_path_name": {
          "type": "string",
          "minLength": 1,
          "description": "完整路径名称"
        },
        "full_path_code": {
          "type": "string",
          "pattern": "^V1/(CH|SEC|SUBSEC)[0-9]{2}(/(CH|SEC|SUBSEC)[0-9]{2})*$",
          "description": "完整路径编码"
        },
        "start_page": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "起始页码"
        },
        "end_page": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "结束页码"
        },
        "node_type": {
          "$ref": "#/definitions/node_type"
        },
        "status": {
          "$ref": "#/definitions/status"
        },
        "source_ref": {
          "type": ["string", "null"],
          "description": "原始教材来源引用"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "结构版本"
        }
      }
    }
  },
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "region_id", "curriculum_version_id", "created_at", "updated_at"],
      "properties": {
        "version": { "type": "string" },
        "region_id": { "type": "string", "const": "CN_AH" },
        "curriculum_version_id": { "type": "string", "const": "PHY_PEP_G1_V1" },
        "subject": { "type": "string", "const": "物理" },
        "grade_level": { "type": "string", "const": "高一" },
        "volume_no": { "type": "string", "const": "必修一" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "chapter_tree": {
      "type": "array",
      "items": { "$ref": "#/definitions/chapter_node" },
      "minItems": 1
    }
  },
  "required": ["metadata", "chapter_tree"]
}
