{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.exa.edu.kg/webhook/canonical-webhook-event-v1.json",
  "title": "Canonical Webhook Event v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "canonical_version",
    "event_id",
    "provider",
    "provider_event_type",
    "provider_action",
    "canonical_type",
    "canonical_action",
    "timestamp",
    "received_at",
    "source",
    "payload",
    "idempotency_key",
    "raw_body_sha256"
  ],
  "properties": {
    "canonical_version": { "const": "v1" },
    "event_id": { "type": "string", "pattern": "^evt_[0-9a-fA-F-]{36}$" },
    "provider": { "type": "string", "enum": ["linear", "github", "slack", "posthog", "pagerduty", "uptime_kuma", "factory"] },
    "provider_event_type": { "type": "string", "minLength": 1 },
    "provider_action": { "type": "string", "minLength": 1 },
    "provider_delivery_id": { "type": "string" },
    "canonical_type": {
      "type": "string",
      "enum": [
        "issue",
        "comment",
        "customer",
        "document",
        "initiative_update",
        "issue_label",
        "project_update",
        "release",
        "customer_request",
        "cycle",
        "emoji_reaction",
        "initiative",
        "issue_attachment",
        "project_label",
        "project",
        "user",
        "issue_sla",
        "push",
        "pull_request",
        "message",
        "alert",
        "metric",
        "factory_run"
      ]
    },
    "canonical_action": { "type": "string", "enum": ["created", "updated", "deleted", "closed", "reopened", "unknown"] },
    "timestamp": { "type": "string", "minLength": 1 },
    "received_at": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "resource_id"],
      "properties": {
        "provider": { "type": "string" },
        "instance_url": { "type": "string" },
        "workspace_id": { "type": "string" },
        "resource_id": { "type": "string" },
        "resource_url": { "type": "string" },
        "project_id": { "type": "string" },
        "team_id": { "type": "string" }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "display_name": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "payload": { "type": "object" },
    "idempotency_key": { "type": "string", "minLength": 3 },
    "raw_body_sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
